# --- API (Docker: docker compose up -d) ---
API_URL=http://localhost:8000
JWT_SECRET=change-me-to-long-random-string

# Postgres (для локального API без Docker — тот же URL)
DATABASE_URL=postgresql+psycopg2://career:career@localhost:5432/career_agent

# --- HeadHunter (вторая авторизация — OAuth в UI) ---
HH_CLIENT_ID=
HH_CLIENT_SECRET=
HH_REDIRECT_URI=http://localhost:8501

# --- LLM ---
# local = MLX на Mac | api = OpenAI-совместимый endpoint
LLM_PROVIDER=local
LLM_LOCAL_MODEL=mlx-community/Qwen2.5-3B-Instruct-4bit

# Облако (если LLM_PROVIDER=api):
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_API_MODEL=google/gemma-2-9b-it

# Дообученный адаптер (после training/train_resume_lora.py):
# RESUME_ADAPTER_PATH=training/output/resume-lora
# LLM_USE_RESUME_ADAPTER=1   # 0 = без LoRA; 1 = дообученный адаптер для адаптации резюме

# Загружать MLX сразу при входе на страницу (0 = при первом запросе к LLM, безопаснее)
# LLM_EAGER_LOAD=0
